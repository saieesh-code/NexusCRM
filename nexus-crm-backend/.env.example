# ─────────────────────────────────────────────
#  NexusCRM — Environment Configuration
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/nexuscrm
# For Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/nexuscrm

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRE=7d
JWT_COOKIE_EXPIRE=7

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Email (Nodemailer — use Mailtrap for dev)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
FROM_EMAIL=noreply@nexuscrm.com
FROM_NAME=NexusCRM

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000

# Logging
LOG_LEVEL=debug
